ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Nebius Token Factory (tier 2 + tier 3 use this key by default).
NEBIUS_API_KEY=

# Optional: agentic run / run-goal orchestrator overrides.
# AGENTIC_ORCHESTRATOR_MODEL=claude-opus-4-7
# AGENTIC_EXTERNAL_MODEL=openai/gpt-4.1
# AGENTIC_EXTERNAL_API_BASE=http://localhost:11434  # e.g. local Ollama
# AGENTIC_MAX_TURNS=30

# Pipeline tier overrides — defaults match Nebius Token Factory + Anthropic.
# AGENTIC_TIER1_MODEL=claude-opus-4-8-high
# AGENTIC_TIER1_MAX_TURNS=20
# AGENTIC_TIER1_API_KEY_ENV=ANTHROPIC_API_KEY
# AGENTIC_TIER1_BASE_URL=                                            # blank → Anthropic default
# AGENTIC_TIER2_MODEL=nvidia/Nemotron-3-Ultra-550b-a55b
# AGENTIC_TIER2_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/
# AGENTIC_TIER2_API_KEY_ENV=NEBIUS_API_KEY
# AGENTIC_TIER3_MODEL=nvidia/Cosmos3-Super-Reasoner
# AGENTIC_TIER3_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# AGENTIC_TIER3_API_KEY_ENV=NEBIUS_API_KEY

# Pipeline state and events.
# AGENTIC_STATE_DIR=state
# AGENTIC_BLOCKS_FILE=BLOCKS.md
# AGENTIC_EVENT_WEBHOOK=                                             # POST every event to this URL

# Per-tier wall-clock budget (seconds). A stage exceeding its budget raises
# TimeoutError; the pipeline records `stage_timeout` and propagates the
# failure so the slug doesn't silently hang.
# AGENTIC_TIER1_WALL_CLOCK_S=300
# AGENTIC_TIER2_WALL_CLOCK_S=180
# AGENTIC_TIER3_WALL_CLOCK_S=300

# Subprocess execution (main.py + app.py boot-check).
# AGENTIC_GPU_COUNT=2                            # slots in the file-locked GPU pool
# AGENTIC_HF_HOME=/data/hf_cache                 # shared HF checkpoint cache;
                                                 # falls back to $HF_HOME, then user default
